# Only Supabase keys are env-driven. Everything else (RPC URL, mint addresses,
# Umbra endpoints, SNS RPC) is hardcoded in lib/{solana,umbra,sns}/constants.ts
# so deploying to Vercel only needs these two variables.
#
# Get them from Supabase dashboard → Project Settings → API:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
